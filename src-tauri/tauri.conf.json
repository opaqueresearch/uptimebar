{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UptimeBar",
  "version": "0.3.0",
  "identifier": "app.uptimebar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popover",
        "url": "index.html",
        "width": 340,
        "height": 440,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": true
      },
      {
        "label": "settings",
        "title": "UptimeBar Settings",
        "url": "settings.html",
        "width": 480,
        "height": 600,
        "visible": false,
        "resizable": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
